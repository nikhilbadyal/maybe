<%= render DS::Dialog.new(variant: "drawer", frame: "bulk_transaction_edit_drawer") do |dialog| %>
  <% dialog.with_header(title: "Edit transactions", data: { bulk_select_target: "bulkEditDrawerHeader" }) %>

  <% dialog.with_body do %>
    <%= styled_form_with url: transactions_bulk_update_path, scope: "bulk_update", class: "h-full flex flex-col justify-between gap-4", data: { turbo_frame: "_top" } do |form| %>
      <div class="space-y-4">
        <%= render DS::Disclosure.new(title: "Overview", open: true) do %>
          <div class="pb-6 space-y-2">
            <%= form.date_field :date, label: "Date", max: Date.current %>
          </div>
        <% end %>

        <%= render DS::Disclosure.new(title: "Transactions", open: true) do %>
          <div class="space-y-2">
            <%# Custom single-select dropdown for Category in bulk updates to prevent mobile select flying bug %>
            <div class="form-field relative" data-controller="select-dropdown">
              <details class="group w-full" data-select-dropdown-target="details">
                <summary class="flex items-center justify-between list-none cursor-pointer">
                  <div class="space-y-0.5">
                    <span class="block text-xs text-secondary">Category</span>
                    <%# Stimulus updates this label in real-time as selection changes %>
                    <span class="text-sm text-primary font-medium block truncate" data-select-dropdown-target="label">
                      Select a category
                    </span>
                  </div>
                  <%= icon "chevron-down", size: "sm", class: "text-secondary transition-transform group-open:rotate-180" %>
                </summary>

                <div class="absolute left-0 right-0 z-50 mt-1 p-2 bg-container shadow-lg border border-secondary rounded-lg space-y-2 max-h-48 overflow-y-auto">
                  <%# Unselected prompt option %>
                  <label class="flex items-center justify-between px-2 py-1.5 hover:bg-surface-hover rounded-md cursor-pointer text-sm text-primary">
                    <%= form.radio_button :category_id, "",
                          checked: true,
                          class: "peer hidden",
                          data: {
                            "select-dropdown-target": "radio",
                            action: "change->select-dropdown#select"
                          } %>
                    <span>Select a category</span>
                    <%= icon "check", size: "sm", class: "hidden peer-checked:block text-primary" %>
                  </label>

                  <%# List of categories %>
                  <% Current.family.categories.alphabetically.each do |category| %>
                    <label class="flex items-center justify-between px-2 py-1.5 hover:bg-surface-hover rounded-md cursor-pointer text-sm text-primary">
                      <%= form.radio_button :category_id, category.id,
                            checked: false,
                            class: "peer hidden",
                            data: {
                              "select-dropdown-target": "radio",
                              action: "change->select-dropdown#select"
                            } %>
                      <span><%= category.name %></span>
                      <%= icon "check", size: "sm", class: "hidden peer-checked:block text-primary" %>
                    </label>
                  <% end %>
                </div>
              </details>
            </div>

            <%# Custom single-select dropdown for Merchant in bulk updates to prevent mobile select flying bug %>
            <div class="form-field relative" data-controller="select-dropdown">
              <details class="group w-full" data-select-dropdown-target="details">
                <summary class="flex items-center justify-between list-none cursor-pointer">
                  <div class="space-y-0.5">
                    <span class="block text-xs text-secondary">Merchant</span>
                    <%# Stimulus updates this label in real-time as selection changes %>
                    <span class="text-sm text-primary font-medium block truncate" data-select-dropdown-target="label">
                      Select a merchant
                    </span>
                  </div>
                  <%= icon "chevron-down", size: "sm", class: "text-secondary transition-transform group-open:rotate-180" %>
                </summary>

                <div class="absolute left-0 right-0 z-50 mt-1 p-2 bg-container shadow-lg border border-secondary rounded-lg space-y-2 max-h-48 overflow-y-auto">
                  <%# Unselected prompt option %>
                  <label class="flex items-center justify-between px-2 py-1.5 hover:bg-surface-hover rounded-md cursor-pointer text-sm text-primary">
                    <%= form.radio_button :merchant_id, "",
                          checked: true,
                          class: "peer hidden",
                          data: {
                            "select-dropdown-target": "radio",
                            action: "change->select-dropdown#select"
                          } %>
                    <span>Select a merchant</span>
                    <%= icon "check", size: "sm", class: "hidden peer-checked:block text-primary" %>
                  </label>

                  <%# List of merchants %>
                  <% Current.family.merchants.alphabetically.each do |merchant| %>
                    <label class="flex items-center justify-between px-2 py-1.5 hover:bg-surface-hover rounded-md cursor-pointer text-sm text-primary">
                      <%= form.radio_button :merchant_id, merchant.id,
                            checked: false,
                            class: "peer hidden",
                            data: {
                              "select-dropdown-target": "radio",
                              action: "change->select-dropdown#select"
                            } %>
                      <span><%= merchant.name %></span>
                      <%= icon "check", size: "sm", class: "hidden peer-checked:block text-primary" %>
                    </label>
                  <% end %>
                </div>
              </details>
            </div>

            <%# Custom multi-select dropdown using details/summary and checkboxes to replace the clunky listbox %>
            <div class="form-field relative" data-controller="multiselect-dropdown">
              <%# Added data-multiselect-dropdown-target="details" to support closing on click-outside %>
              <details class="group w-full" data-multiselect-dropdown-target="details">
                <summary class="flex items-center justify-between list-none cursor-pointer">
                  <div class="space-y-0.5">
                    <span class="block text-xs text-secondary">Tags</span>
                    <%# Stimulus updates this label in real-time as checkboxes change %>
                    <span class="text-sm text-primary font-medium block truncate" data-multiselect-dropdown-target="label">
                      Select tags...
                    </span>
                  </div>
                  <%= icon "chevron-down", size: "sm", class: "text-secondary transition-transform group-open:rotate-180" %>
                </summary>

                <div class="absolute left-0 right-0 z-50 mt-1 p-2 bg-container shadow-lg border border-secondary rounded-lg space-y-2 max-h-48 overflow-y-auto">
                  <%# Hidden input to ensure that empty tags array is submitted to clear all tags %>
                  <input type="hidden" name="bulk_update[tag_ids][]" value="">

                  <% Current.family.tags.alphabetically.each do |tag| %>
                    <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-surface-hover rounded-md cursor-pointer text-sm text-primary">
                      <%= check_box_tag "bulk_update[tag_ids][]",
                                        tag.id,
                                        false,
                                        id: "bulk_tag_#{tag.id}",
                                        class: "checkbox checkbox--light shrink-0",
                                        data: {
                                          "multiselect-dropdown-target": "checkbox",
                                          action: "change->multiselect-dropdown#updateLabel"
                                        } %>
                      <span><%= tag.name %></span>
                    </label>
                  <% end %>
                </div>
              </details>
            </div>
            <%= form.text_area :notes, label: "Notes", placeholder: "Enter a note that will be applied to selected transactions", rows: 5 %>
          </div>
        <% end %>
      </div>

      <div class="flex justify-end gap-2 mt-auto">
        <%= render DS::Button.new(text: "Cancel", variant: "ghost", data: { action: "click->dialog#close" }) %>
        <%= render DS::Button.new(text: "Save", data: { bulk_select_scope_param: "bulk_update", action: "bulk-select#submitBulkRequest" }) %>
      </div>
    <% end %>
  <% end %>
<% end %>
